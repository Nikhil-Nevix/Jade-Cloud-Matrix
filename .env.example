# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jade_user:jade_pass@localhost:5432/jade_db

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET_KEY=change-this-to-a-random-32-char-minimum-string-for-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─── App ─────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── AI (Claude API) ─────────────────────────────────────
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Live Cloud Pricing APIs (optional — falls back to hardcoded data) ───
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AZURE_SUBSCRIPTION_ID=
GCP_PROJECT_ID=

# ─── Ingestion Schedule ───────────────────────────────────
INGESTION_HOUR=2
INGESTION_MINUTE=0
