# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jade_user:jade_pass@localhost:5433/jade_db

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ─── App ─────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── AI (Claude API) ─────────────────────────────────────
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Live Cloud Pricing APIs (optional — falls back to hardcoded data) ───
# AWS credentials (for real-time pricing)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=us-east-1

# Azure credentials (for real-time pricing)
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_TENANT_ID=your_azure_tenant_id

# GCP credentials (for real-time pricing)
GCP_PROJECT_ID=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ─── Pricing API Mode ─────────────────────────────────────
# Options: "live" or "fallback"
# live = fetch from cloud provider APIs (requires credentials above)
# fallback = use hardcoded pricing data (no credentials needed)
PRICING_API_MODE=fallback

# ─── Ingestion Schedule ───────────────────────────────────
INGESTION_HOUR=2
INGESTION_MINUTE=0